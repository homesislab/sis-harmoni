# SIS Harmoni
# Catatan: CodeIgniter 3 tidak otomatis membaca file .env.
# Jalankan `composer install` agar .env ter-load via vlucas/phpdotenv (lihat index.php).

ENVIRONMENT=production

SIS_HARMONI_BASE_URL=https://warga.homesislab.my.id/
SIS_HARMONI_APP_URL=https://sis-harmoni.vercel.app

SIS_HARMONI_DB_HOST=mariadb_server
SIS_HARMONI_DB_PORT=3306
SIS_HARMONI_DB_NAME=sis_harmoni
SIS_HARMONI_DB_USER=sis_harmoni
SIS_HARMONI_DB_PASS=sis_harmoni123

# Security
# Gunakan random 64-hex (256-bit). Ganti di production.
SIS_HARMONI_JWT_SECRET=d7c4a3f30371f583f05d1872d9b7cc54a7cbed726d964883a3b75541293f9566
SIS_HARMONI_JWT_ISS=sis-harmoni
SIS_HARMONI_JWT_TTL=86400

# WhatsApp Integration
WABOT_USERNAME=admin
WABOT_PASSWORD=adminpassword
WABOT_SESSION_ID=homesislab
WABOT_GROUP_PENGURUS_PHONE=120363406633435268@g.us
WABOT_ADMIN_KEUANGAN_PHONE=120363406633435268@g.us
WABOT_ADMIN_SECURITY_PHONE=120363406633435268@g.us

# Upload storage
SIS_UPLOAD_DRIVER=auto
CLOUDINARY_CLOUD_NAME=
